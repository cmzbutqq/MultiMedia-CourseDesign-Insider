{
  "server": {
    "host": "0.0.0.0",
    "port": 5000,
    "debug": false,
    "cors_origins": "*"
  },
  "gesture_detection": {
    "model_complexity": 0,
    "num_hands": 1,
    "min_detection_confidence": 0.7,
    "min_hand_presence_confidence": 0.7,
    "min_tracking_confidence": 0.5,
    "use_gpu": true
  },
  "gesture_thresholds": {
    "pinch": 0.07,
    "drag": 0.02,
    "rotate": 0.1
  },
  "performance": {
    "max_fps": 30,
    "frame_skip": 0,
    "batch_size": 1
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  }
}
